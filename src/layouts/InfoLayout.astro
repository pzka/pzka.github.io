---
import RootLayout from "./RootLayout.astro";
import Footer from "../components/footer.astro";
import WarpBackground from "../components/warp-background";

const { title, description } = Astro.props;

const pathname = Astro.url.pathname;
---

<RootLayout title={title} description={description}>
	<div class="flex relative gap-4 w-full max-w-screen-xl">
		<nav class="relative w-4 md:min-w-2xs xl:min-w-sm sm:min-h-screen sm:ml-4 sm:pb-4">

		  <!-- DESKTOP: side pillar (unchanged vibe) -->
		  <div class="hidden md:block w-full h-full fixed -z-10 sm:bottom-4 sm:rounded-b-full overflow-hidden">
		    <WarpBackground
		      color1="#e5e5e5"
		      color2="#a1a1aa"
		      color3="#27272a"
		      speed={0.15}
		      swirl={1.5}
		      swirlIterations={10}
		      shapeScale={0.3}
		      client:load
		    />
		  </div>
		
		</nav>

		<!-- MOBILE: full background -->
		<div class="md:hidden fixed inset-0 -z-20">
		  <WarpBackground
		    color1="#e5e5e5"
		    color2="#a1a1aa"
		    color3="#27272a"
		    speed={0.15}
		    swirl={1.5}
		    swirlIterations={10}
		    shapeScale={0.3}
		    client:load
		  />
		</div>

		<!-- MOBILE: white overlay for readability -->
		<div class="md:hidden fixed inset-0 bg-white/85 -z-10"></div>

		<main class="relative"  >
			<slot />
			<Footer />
		</main>


	</div>
</RootLayout>
