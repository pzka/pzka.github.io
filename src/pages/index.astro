---
import H1 from "../components/h1.astro";
import Link from "../components/link.astro";
import Navigation from "../components/navigation";
import RootLayout from "../layouts/RootLayout.astro";
import WarpBackground from "../components/warp-background";
import AvailableForWork from "../components/available.astro";
---

<RootLayout>
	<main>
		<div class="group relative w-full min-h-dvh flex items-center justify-center">
			<div class="absolute w-full h-dvh -z-10">
				<WarpBackground
					color1="#09090b"
					color2="#27272a"
					color3="#52525b"
					speed={0.6}
					swirl={0.5}
					swirlIterations={10}
					shapeScale={0.3}
					client:load
				/>
			</div>

			<div class="p-4 sm:p-8 absolute w-full h-dvh flex flex-col justify-between z-10">
				
				<!-- TOP: Your Name + Identity -->
				<div>
					<H1 size="large">
						Josia Paska Darmawan is an <br /> Impact Strategist
					</H1>
				</div>

				<!-- BOTTOM: Actions -->
				<div>
					<<span class="italic">(n.) Impact Strategist</span>: A person who maps complexity, 
					identifies leverage points, and turns ideas into systems that create real-world impact. className="py-4" />

					<div class="mb-2 sm:mb-4 flex items-center justify-between">
						
						<div class="flex items-center gap-4">
							<Link href="/contact" >Work with me</Link>
							<Link href="/about" variant="secondary">About me</Link>
							<Link href="/projects" variant="secondary">What I do</Link>
							<Link href="/news" variant="secondary">Latest events</Link>
						</div>
					</div>
				</div>

			</div>
		</div>
	</main>
</RootLayout>
